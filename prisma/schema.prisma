datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

// ------------------------------------------------------------------
// Modelos Obrigatórios do NextAuth.js
// ------------------------------------------------------------------

model Account {
  id                 String  @id @default(cuid())
  userId             String
  type               String
  provider           String
  providerAccountId  String
  refresh_token      String?  
  access_token       String?  
  expires_at         Int?
  token_type         String?
  scope              String?
  id_token           String?  
  session_state      String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  role          String    @default("visitante") // admin, colaborador, visitante
  
  accounts      Account[]
  sessions      Session[]
  
  // Relações customizadas planILHA
  empresas      Empresa[]

  // Integração Meta (Acesso global do usuário)
  metaAccessToken String?
  metaName        String?
  metaPhoto       String?

  // Relacionamento de Visitante (Sem Empresa associada)
  visitorProfile  VisitorProfile?

  // Comentários do Kanban
  comentariosCard CardComentario[]
}

// ------------------------------------------------------------------
// Modelos de Visitantes e Onboarding (Product-Led Growth)
// ------------------------------------------------------------------

model VisitorProfile {
  id                  String   @id @default(cuid())
  userId              String   @unique
  personaType         String   // "Dono de Marca" ou "Profissional de Marketing"
  marketNiche         String   // Ex: "E-commerce", "SaaS", "Serviços locais"
  marketingInvestment String   // Ex: "< 5k", "5k-20k", "> 20k"
  primaryChannels     String[] // Canais prioritários de mídias pagas
  primaryChannelUrl   String?
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  @@index([userId])
}

model TenantCrmMetadata {
  id                  String   @id @default(cuid())
  empresaId           String   @unique
  importedPersona     String?
  importedNiche       String?
  importedInvestment  String?
  historicalOnboardingData Json?
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  empresa Empresa @relation(fields: [empresaId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ------------------------------------------------------------------
// Modelos Customizados do planILHA
// ------------------------------------------------------------------

model Empresa {
  id          String   @id @default(cuid())
  name        String
  avatarUrl   String?
  platform    String   @default("Instagram")
  status      String   @default("Ativo")
  statusType  String   @default("success")
  
  websiteUrl      String?
  instagramUrl    String?
  facebookUrl     String?
  coverUrl        String?
  
  // Integração Meta (Graph API)
  metaPageId      String?
  igAccountId     String?
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  // Relação N:N com Usuários (quais usuários tem acesso a esta empresa)
  usuarios    User[]
  
  // Posts agendados e Leads
  posts       PostAgendado[]
  leads       Lead[]

  // CRM Metadata do Onboarding
  crmMetadata TenantCrmMetadata?
  
  // Planejamentos Estratégicos (Kanban)
  planejamentos Planejamento[]
  
  // Relatórios Gerados
  relatoriosGerados RelatorioGerado[]
}

model Lead {
  id          String   @id @default(cuid())
  empresaId   String
  nome        String
  email       String?
  telefone    String?
  origem      String   @default("Manual") // Manual, Meta Ads, etc.
  status      String   @default("Novo")   // Novo, Contatado, Fechado, Perdido
  createdAt   DateTime @default(now())

  empresa     Empresa  @relation(fields: [empresaId], references: [id], onDelete: Cascade)
}

model PostAgendado {
  id          String   @id @default(cuid())
  empresaId   String
  midiaUrl    String?
  legenda     String?
  rede        String   @default("Instagram")
  formato     String   @default("Feed") // Feed, Reels, Stories, Carrossel
  dataHora    DateTime
  status      String   @default("Agendado") // Agendado, Publicado, Erro
  advancedConfig Json?
  
  criadoPor   String?
  createdAt   DateTime @default(now())

  empresa     Empresa  @relation(fields: [empresaId], references: [id], onDelete: Cascade)
}

// ------------------------------------------------------------------
// Modelos de Planejamento (Kanban)
// ------------------------------------------------------------------

model Planejamento {
  id          String   @id @default(cuid())
  empresaId   String?
  titulo      String
  descricao   String?
  criadoPor   String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  empresa     Empresa? @relation(fields: [empresaId], references: [id], onDelete: Cascade)
  colunas     Coluna[]
}

model Coluna {
  id              String   @id @default(cuid())
  planejamentoId  String
  titulo          String
  icone           String?
  ordem           Int      @default(0)
  createdAt       DateTime @default(now())

  planejamento    Planejamento @relation(fields: [planejamentoId], references: [id], onDelete: Cascade)
  cards           Card[]
}

model Card {
  id           String   @id @default(cuid())
  colunaId     String
  titulo       String
  descricao    String?
  demanda      String?
  ordem        Int      @default(0)
  dataVencimento DateTime?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @default(now()) @updatedAt

  coluna       Coluna        @relation(fields: [colunaId], references: [id], onDelete: Cascade)
  labels       CardLabel[]
  checklists   CardChecklist[]
  comentarios  CardComentario[]
  anexos       CardAnexo[]
}

model CardLabel {
  id      String @id @default(cuid())
  cardId  String
  nome    String
  cor     String @default("#22c55e") // hex color
  
  card    Card   @relation(fields: [cardId], references: [id], onDelete: Cascade)
}

model CardChecklist {
  id     String @id @default(cuid())
  cardId String
  titulo String @default("Checklist")
  
  card   Card             @relation(fields: [cardId], references: [id], onDelete: Cascade)
  itens  ChecklistItem[]
}

model ChecklistItem {
  id          String        @id @default(cuid())
  checklistId String
  texto       String
  concluido   Boolean       @default(false)
  ordem       Int           @default(0)
  
  checklist   CardChecklist @relation(fields: [checklistId], references: [id], onDelete: Cascade)
}

model CardComentario {
  id        String   @id @default(cuid())
  cardId    String
  userId    String
  texto     String
  createdAt DateTime @default(now())
  
  card      Card     @relation(fields: [cardId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model CardAnexo {
  id        String   @id @default(cuid())
  cardId    String
  nome      String
  url       String
  createdAt DateTime @default(now())
  
  card      Card     @relation(fields: [cardId], references: [id], onDelete: Cascade)
}

// ------------------------------------------------------------------
// Modelos de Relatórios
// ------------------------------------------------------------------

model RelatorioGerado {
  id            String   @id @default(cuid())
  empresaId     String
  dias          Int
  platform      String   @default("INSTAGRAM")
  aiAnalysis    Json?
  dadosCongelados Json
  criadoPor     String?
  createdAt     DateTime @default(now())

  empresa       Empresa  @relation(fields: [empresaId], references: [id], onDelete: Cascade)
}
