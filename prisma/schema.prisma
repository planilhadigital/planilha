datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

// ------------------------------------------------------------------
// Modelos Obrigatórios do NextAuth.js
// ------------------------------------------------------------------

model Account {
  id                 String  @id @default(cuid())
  userId             String
  type               String
  provider           String
  providerAccountId  String
  refresh_token      String?  
  access_token       String?  
  expires_at         Int?
  token_type         String?
  scope              String?
  id_token           String?  
  session_state      String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  role          String    @default("colaborador") // admin, colaborador, cliente
  
  accounts      Account[]
  sessions      Session[]
  
  // Relações customizadas planILHA
  empresas      Empresa[]

  // Integração Meta (Acesso global do usuário)
  metaAccessToken String?
  metaName        String?
  metaPhoto       String?
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ------------------------------------------------------------------
// Modelos Customizados do planILHA
// ------------------------------------------------------------------

model Empresa {
  id          String   @id @default(cuid())
  name        String
  avatarUrl   String?
  platform    String   @default("Instagram")
  status      String   @default("Ativo")
  statusType  String   @default("success")
  
  websiteUrl      String?
  instagramUrl    String?
  facebookUrl     String?
  coverUrl        String?
  
  // Integração Meta (Graph API)
  metaPageId      String?
  igAccountId     String?
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  // Relação N:N com Usuários (quais usuários tem acesso a esta empresa)
  usuarios    User[]
  
  // Posts agendados
  posts       PostAgendado[]
}

model PostAgendado {
  id          String   @id @default(cuid())
  empresaId   String
  midiaUrl    String?
  legenda     String?
  rede        String   @default("Instagram")
  dataHora    DateTime
  status      String   @default("Agendado") // Agendado, Publicado, Erro
  
  criadoPor   String?
  createdAt   DateTime @default(now())

  empresa     Empresa  @relation(fields: [empresaId], references: [id], onDelete: Cascade)
}

// ------------------------------------------------------------------
// Modelos de Planejamento (Kanban)
// ------------------------------------------------------------------

model Planejamento {
  id          String   @id @default(cuid())
  titulo      String
  descricao   String?
  criadoPor   String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  colunas     Coluna[]
}

model Coluna {
  id              String   @id @default(cuid())
  planejamentoId  String
  titulo          String
  icone           String?
  ordem           Int      @default(0)
  createdAt       DateTime @default(now())

  planejamento    Planejamento @relation(fields: [planejamentoId], references: [id], onDelete: Cascade)
  cards           Card[]
}

model Card {
  id          String   @id @default(cuid())
  colunaId    String
  titulo      String
  descricao   String?
  ordem       Int      @default(0)
  createdAt   DateTime @default(now())

  coluna      Coluna   @relation(fields: [colunaId], references: [id], onDelete: Cascade)
}
